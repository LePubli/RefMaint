# PostgreSQL
POSTGRES_DB=trimaint
POSTGRES_USER=trimaint
POSTGRES_PASSWORD=changeme_use_openssl_rand_hex_16

# Backend — obligatoire en production
# Générer avec : openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-64-char-secret-key-for-production

# CORS : origines autorisées (séparées par virgule)
# Vide par défaut = localhost uniquement en dev.
CORS_ORIGINS=https://trimaint.example.com

# API docs (Swagger / ReDoc). false en production.
ENABLE_API_DOCS=false

# Port exposé par le frontend (default 80)
PORT=80
